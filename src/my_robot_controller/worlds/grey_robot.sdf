<sdf version="1.8">
  <model name="grey_robot">
    <self_collide>false</self_collide>

    <link name="chassis">
      <pose>0 0 0.5 0 0 0</pose>
      <inertial>
        <pose>-0.2 0 -0.25 0 0 0</pose> 
        <mass>15.0</mass>
        <inertia>
          <ixx>0.5</ixx>
          <iyy>0.5</iyy>
          <izz>0.5</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><box><size>0.8 0.6 0.08</size></box></geometry>
        <material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material>
      </visual>
      <collision name="chassis_collision">
        <geometry><box><size>0.8 0.6 0.08</size></box></geometry>
      </collision>
    </link>

    <link name="body_L"><pose>0.3 0.3 0.5 0 0 0</pose><visual name="visual"><geometry><box><size>0.1 0.1 0.1</size></box></geometry></visual></link>
    <link name="axle_L"><pose>0.3 0.3 0.15 1.5708 0 0</pose><visual name="visual"><geometry><cylinder><radius>0.02</radius><length>0.15</length></cylinder></geometry><material><ambient>1 0 0 1</ambient></material></visual></link>
    <link name="tire_L">
      <pose>0.3 0.35 0.15 1.5708 0 0</pose> 
      <collision name="collision"><geometry><cylinder><radius>0.15</radius><length>0.05</length></cylinder></geometry></collision>
      <visual name="visual"><geometry><cylinder><radius>0.15</radius><length>0.05</length></cylinder></geometry></visual>
    </link>

    <link name="body_R"><pose>0.3 -0.3 0.5 0 0 0</pose><visual name="visual"><geometry><box><size>0.1 0.1 0.1</size></box></geometry></visual></link>
    <link name="axle_R"><pose>0.3 -0.3 0.15 1.5708 0 0</pose><visual name="visual"><geometry><cylinder><radius>0.02</radius><length>0.15</length></cylinder></geometry><material><ambient>1 0 0 1</ambient></material></visual></link>
    <link name="tire_R">
      <pose>0.3 -0.35 0.15 1.5708 0 0</pose> 
      <collision name="collision"><geometry><cylinder><radius>0.15</radius><length>0.05</length></cylinder></geometry></collision>
      <visual name="visual"><geometry><cylinder><radius>0.15</radius><length>0.05</length></cylinder></geometry></visual>
    </link>

    <link name="caster_housing"><pose>-0.3 0 0.5 0 0 0</pose><visual name="visual"><geometry><box><size>0.1 0.1 0.1</size></box></geometry></visual></link>
    <link name="caster_ball">
      <pose>-0.3 0 0.15 0 0 0</pose>
      <collision name="collision">
        <geometry><sphere><radius>0.1</radius></sphere></geometry>
        <surface>
          <friction><ode><mu>0.01</mu><mu2>0.01</mu2><slip1>1.0</slip1><slip2>1.0</slip2></ode></friction>
          <contact><ode><soft_cfm>0.01</soft_cfm><kp>1000000.0</kp><kd>1.0</kd></ode></contact>
        </surface>
      </collision>
      <visual name="visual"><geometry><sphere><radius>0.1</radius></sphere></geometry></visual>
    </link>

    <joint name="ch_to_L" type="fixed"><parent>chassis</parent><child>body_L</child></joint>
    <joint name="ch_to_R" type="fixed"><parent>chassis</parent><child>body_R</child></joint>
    <joint name="ch_to_C" type="fixed"><parent>chassis</parent><child>caster_housing</child></joint>

    <joint name="suspension_L" type="prismatic">
      <parent>body_L</parent><child>axle_L</child>
      <axis>
        <xyz expressed_in="__model__">0 0 1</xyz>
        <limit><lower>-0.15</lower><upper>0.15</upper></limit> 
        <dynamics><spring_stiffness>2000.0</spring_stiffness><damping>450.0</damping></dynamics>
      </axis>
    </joint>

    <joint name="suspension_R" type="prismatic">
      <parent>body_R</parent><child>axle_R</child>
      <axis>
        <xyz expressed_in="__model__">0 0 1</xyz>
        <limit><lower>-0.15</lower><upper>0.15</upper></limit>
        <dynamics><spring_stiffness>2000.0</spring_stiffness><damping>450.0</damping></dynamics>
      </axis>
    </joint>

    <joint name="suspension_caster" type="prismatic">
      <parent>caster_housing</parent><child>caster_ball</child>
      <axis>
        <xyz expressed_in="__model__">0 0 1</xyz>
        <limit><lower>-0.02</lower><upper>0.02</upper></limit>
        <dynamics><spring_stiffness>5000.0</spring_stiffness><damping>500.0</damping></dynamics>
      </axis>
    </joint>

    <joint name="drive_L" type="revolute"><parent>axle_L</parent><child>tire_L</child><axis><xyz expressed_in="__model__">0 1 0</xyz></axis></joint>
    <joint name="drive_R" type="revolute"><parent>axle_R</parent><child>tire_R</child><axis><xyz expressed_in="__model__">0 1 0</xyz></axis></joint>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher"/>
    <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce"><joint_name>suspension_L</joint_name></plugin>
    <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce"><joint_name>suspension_R</joint_name></plugin>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>drive_L</left_joint>
      <right_joint>drive_R</right_joint>
      <wheel_separation>0.7</wheel_separation>
      <wheel_radius>0.15</wheel_radius>
      <topic>cmd_vel</topic>
      <max_linear_acceleration>0.4</max_linear_acceleration>
      <max_wheel_torque>35.0</max_wheel_torque> 
    </plugin>
  </model>
</sdf>