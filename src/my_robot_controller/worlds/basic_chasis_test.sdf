<sdf version="1.8">
  <model name="social_robot_base">
    <self_collide>false</self_collide>

    <link name="chassis">
      <pose>0 0 0.5 0 0 0</pose> <inertial>
        <mass>10.0</mass> <inertia>
          <ixx>0.5</ixx><iyy>0.5</iyy><izz>0.5</izz>
        </inertia>
      </inertial>
      <collision name="chassis_collision">
        <geometry><box><size>0.4 0.6 0.05</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>0.4 0.6 0.05</size></box></geometry>
        <material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material>
      </visual>
    </link>

    <link name="body_L">
      <pose>0 0.3 0.5 0 0 0</pose>
      <inertial>
        <mass>2.0</mass> <inertia><ixx>0.1</ixx><iyy>0.1</iyy><izz>0.1</izz></inertia>
      </inertial>
      <visual name="visual">
        <geometry><box><size>0.2 0.2 0.1</size></box></geometry>
      </visual>
    </link>

    <link name="wheel_L">
      <pose>0 0.3 0.15 0 0 0</pose> 
      <inertial>
        <mass>1.5</mass> <inertia><ixx>0.02</ixx><iyy>0.02</iyy><izz>0.02</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.15</radius><length>0.1</length></cylinder></geometry>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.15</radius><length>0.1</length></cylinder></geometry>
      </visual>
    </link>

    <link name="body_R">
      <pose>0 -0.3 0.5 0 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia><ixx>0.1</ixx><iyy>0.1</iyy><izz>0.1</izz></inertia>
      </inertial>
      <visual name="visual">
        <geometry><box><size>0.2 0.2 0.1</size></box></geometry>
      </visual>
    </link>

    <link name="wheel_R">
      <pose>0 -0.3 0.15 0 0 0</pose> 
      <inertial>
        <mass>1.5</mass>
        <inertia><ixx>0.02</ixx><iyy>0.02</iyy><izz>0.02</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.15</radius><length>0.1</length></cylinder></geometry>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.15</radius><length>0.1</length></cylinder></geometry>
      </visual>
    </link>

    <joint name="chassis_to_body_L" type="fixed"><parent>chassis</parent><child>body_L</child></joint>
    <joint name="chassis_to_body_R" type="fixed"><parent>chassis</parent><child>body_R</child></joint>

    <joint name="suspension_L" type="prismatic">
      <parent>body_L</parent>
      <child>wheel_L</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-0.1</lower><upper>0.1</upper></limit>
        <dynamics>
          <damping>3.0</damping>          
          
          <spring_stiffness>400.0</spring_stiffness> 
          
          <spring_reference>0.0</spring_reference>
        </dynamics>

      </axis>
    </joint>

    <joint name="suspension_R" type="prismatic">
      <parent>body_R</parent>
      <child>wheel_R</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-0.1</lower><upper>0.1</upper></limit>
        <dynamics>
          <damping>3.0</damping>          
          
          <spring_stiffness>400.0</spring_stiffness> 
          
          <spring_reference>0.0</spring_reference>
        </dynamics>
        
      </axis>
    </joint>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <joint_name>suspension_L</joint_name>
      <joint_name>suspension_R</joint_name>
    </plugin>
  </model>
</sdf>